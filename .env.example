# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# e.g. https://royal-slots.onrender.com
APP_URL="https://your-app.onrender.com"

# DATABASE_URL: Neon PostgreSQL connection string (REQUIRED).
# Set this in your Render dashboard under Environment > Environment Variables.
DATABASE_URL="postgresql://neondb_owner:<password>@<host>/neondb?sslmode=require&channel_binding=require"

# Google OAuth Client ID for Sheets & Drive integration
GOOGLE_CLIENT_ID=""

# SMTP credentials for email notifications (optional)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# PORT is automatically injected by Render — do not set this manually in production
# PORT=3000
